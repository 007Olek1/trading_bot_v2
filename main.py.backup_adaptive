    def update_watchlist(self):
        """Обновление списка монет для сканирования"""
        from datetime import datetime, timedelta
        
        # Проверяем нужно ли обновлять
        if self.last_watchlist_update:
            time_since_update = datetime.now() - self.last_watchlist_update
            if time_since_update < timedelta(hours=config.UPDATE_WATCHLIST_HOURS):
                return self.current_watchlist
        
        if config.USE_DYNAMIC_SCANNER:
            self.logger.info("🔍 Обновление списка ликвидных монет...")
            self.current_watchlist = self.market_scanner.get_liquid_symbols(
                min_volume_24h=config.MIN_VOLUME_24H_USD,
                limit=config.MAX_SYMBOLS_TO_SCAN
            )
            self.last_watchlist_update = datetime.now()
            self.logger.info(f"✅ Watchlist обновлён: {len(self.current_watchlist)} монет")
        else:
            self.current_watchlist = config.WATCHLIST
        
        return self.current_watchlist
    
