    def get_klines(self, symbol: str, interval: str, limit: int = 200) -> Optional[pd.DataFrame]:
        """Получение свечей с биржи"""
        try:
            self.logger.debug(f"Запрос данных: {symbol} {interval}")
            
            response = self.client.get_kline(
                category="linear",
                symbol=symbol,
                interval=interval,
                limit=limit
            )
            
            if response['retCode'] != 0:
                error_msg = response.get('retMsg', 'Unknown error')
                # Тихо игнорируем невалидные символы (это норма для некоторых пар)
                if 'Symbol Is Invalid' not in error_msg and '10001' not in str(response.get('retCode', '')):
                    self.logger.warning(f"Ошибка получения данных для {symbol} {interval}: {error_msg}")
                return None
            
            klines = response['result']['list']
            
            if not klines:
                self.logger.warning(f"Пустой список свечей для {symbol} {interval}")
                return None
            
            # Создаём DataFrame
            df = pd.DataFrame(klines, columns=[
                'timestamp', 'open', 'high', 'low', 'close', 'volume', 'turnover'
            ])
            
            # Конвертируем типы
            df['timestamp'] = pd.to_datetime(df['timestamp'].astype(int), unit='ms')
            for col in ['open', 'high', 'low', 'close', 'volume']:
                df[col] = df[col].astype(float)
            
            # Сортируем по времени (от старых к новым)
            df = df.sort_values('timestamp').reset_index(drop=True)
            
            return df
            
        except Exception as e:
            # Не логируем ошибки для невалидных символов (это норма)
            error_str = str(e)
            if 'Symbol Is Invalid' not in error_str and '10001' not in error_str:
                self.logger.error(f"Ошибка get_klines для {symbol} {interval}: {e}")
            return None
    
    def get_mtf_data(self, symbol: str) -> Dict[str, pd.DataFrame]:
        """Получение данных по всем таймфреймам"""
        mtf_data = {}
        
        for tf_name, tf_value in config.TIMEFRAMES.items():
            df = self.get_klines(symbol, tf_value, limit=200)
            if df is not None and len(df) > 0:
                mtf_data[tf_name] = df
        
        return mtf_data
    
