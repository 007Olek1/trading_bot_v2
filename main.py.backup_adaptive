    def analyze_mtf_signal(self, symbol: str, mtf_data: Dict[str, pd.DataFrame]) -> Optional[Dict]:
        """
        Анализ сигнала по всем таймфреймам
        Возвращает: {'direction': 'LONG'/'SHORT', 'confidence': 0.0-1.0, 'details': {...}}
        """
        if not mtf_data or len(mtf_data) < config.MIN_TIMEFRAME_ALIGNMENT:
            return None
        
        signals = {}
        
        # Анализ каждого таймфрейма
        for tf_name, df in mtf_data.items():
            if len(df) < 50:  # Недостаточно данных
                continue
            
            # Рассчитываем индикаторы
            indicators = self.indicators.calculate_all(df)
            
            # Применяем стратегии
            strategy_signals = {}
            
            # 1. Тренд + Объём + Bollinger
            if config.STRATEGIES['trend_volume_bb']['enabled']:
                trend_signal = self.trend_volume_strategy.analyze(df, indicators)
                strategy_signals['trend_volume_bb'] = trend_signal
            
            # 2. Детектор манипуляций
            if config.STRATEGIES['manipulation_detector']['enabled']:
                manip_signal = self.manipulation_detector.analyze(df, indicators)
                strategy_signals['manipulation_detector'] = manip_signal
            
            # 3. Глобальный тренд (только для 4h и 1d)
            if config.STRATEGIES['global_trend']['enabled'] and tf_name in ['4h', '1d']:
                global_signal = self.global_trend_analyzer.analyze(df, indicators)
                strategy_signals['global_trend'] = global_signal
            
            # Объединяем сигналы стратегий
            tf_signal = self._combine_strategy_signals(strategy_signals)
            signals[tf_name] = tf_signal
        
        # Объединяем сигналы всех таймфреймов
        final_signal = self._combine_mtf_signals(signals)
        
        # Детальное логирование
        if final_signal:
            tf_count = final_signal.get('timeframes_aligned', 0)
            confidence = final_signal.get('confidence', 0.0)
            direction = final_signal.get('direction', 'NONE')
            
            # Проверяем условия
            if confidence < config.SIGNAL_THRESHOLDS['min_confidence']:
                self.logger.debug(
                    f"  {symbol}: {direction} отклонён - "
                    f"уверенность {confidence:.1%} < {config.SIGNAL_THRESHOLDS['min_confidence']:.1%}"
                )
                return None
            
            if tf_count < config.MIN_TIMEFRAME_ALIGNMENT:
                self.logger.debug(
                    f"  {symbol}: {direction} отклонён - "
                    f"таймфреймов {tf_count}/{len(signals)} < {config.MIN_TIMEFRAME_ALIGNMENT}"
                )
                return None
            
            # Сигнал прошёл все проверки!
            self.logger.info(
                f"🎯 КАНДИДАТ: {symbol} {direction} | "
                f"Уверенность: {confidence:.1%} | TF: {tf_count}/{len(signals)}"
            )
            
            # Отправляем уведомление в Telegram о кандидате
            try:
                current_price = mtf_data[config.PRIMARY_TIMEFRAME]['close'].iloc[-1]
                asyncio.create_task(
                    self.telegram.send_candidate_alert(
                        symbol=symbol,
                        direction=direction,
                        confidence=confidence,
                        tf_aligned=tf_count,
                        total_tf=len(signals),
                        price=current_price
                    )
                )
            except Exception as e:
                self.logger.error(f"Ошибка отправки уведомления о кандидате: {e}")
            
            return final_signal
        
        return None
    
    def _combine_strategy_signals(self, strategy_signals: Dict) -> Dict:
        """Объединение сигналов разных стратегий"""
        if not strategy_signals:
            return {'direction': None, 'confidence': 0.0}
        
        long_weight = 0.0
        short_weight = 0.0
        total_weight = 0.0
        
        for strategy_name, signal in strategy_signals.items():
            if signal is None or signal['direction'] is None:
                continue
            
            weight = config.STRATEGIES.get(strategy_name, {}).get('weight', 0.0)
            confidence = signal.get('confidence', 0.0)
            
            if signal['direction'] == 'LONG':
                long_weight += weight * confidence
            elif signal['direction'] == 'SHORT':
                short_weight += weight * confidence
            
            total_weight += weight
        
        if total_weight == 0:
            return {'direction': None, 'confidence': 0.0}
        
        # Определяем направление
        if long_weight > short_weight:
            direction = 'LONG'
            confidence = long_weight / total_weight
        elif short_weight > long_weight:
            direction = 'SHORT'
            confidence = short_weight / total_weight
        else:
            direction = None
            confidence = 0.0
        
        return {
            'direction': direction,
            'confidence': confidence,
            'long_weight': long_weight,
            'short_weight': short_weight
        }
    
    def _combine_mtf_signals(self, signals: Dict[str, Dict]) -> Optional[Dict]:
        """Объединение сигналов всех таймфреймов"""
        if not signals:
            return None
        
        # Подсчитываем голоса
        long_votes = 0
        short_votes = 0
        total_confidence = 0.0
        
        for tf_name, signal in signals.items():
            if signal['direction'] == 'LONG':
                long_votes += 1
                total_confidence += signal['confidence']
            elif signal['direction'] == 'SHORT':
                short_votes += 1
                total_confidence += signal['confidence']
        
        total_votes = long_votes + short_votes
        
        if total_votes < config.MIN_TIMEFRAME_ALIGNMENT:
            return None
        
        # Определяем направление
        if long_votes > short_votes:
            direction = 'LONG'
            alignment = long_votes / len(signals)
        elif short_votes > long_votes:
            direction = 'SHORT'
            alignment = short_votes / len(signals)
        else:
            return None  # Нет консенсуса
        
        # Средняя уверенность
        avg_confidence = total_confidence / total_votes if total_votes > 0 else 0.0
        
        # Финальная уверенность с учётом выравнивания
        final_confidence = avg_confidence * alignment
        
        return {
            'direction': direction,
            'confidence': final_confidence,
            'timeframes_aligned': total_votes,
            'total_timeframes': len(signals),
            'alignment_ratio': alignment,
            'details': signals
        }
    
