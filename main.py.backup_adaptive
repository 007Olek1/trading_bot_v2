    async def scan_and_trade(self):
        """Сканирование рынка и открытие позиций"""
        self.logger.info("🔍 Начинаю сканирование рынка...")
        
        # Обновляем watchlist
        watchlist = self.update_watchlist()
        
        # Рассчитываем сколько слотов доступно для новых позиций
        available_slots = config.MAX_CONCURRENT_POSITIONS - len(self.open_positions)
        
        if available_slots <= 0:
            self.logger.info(f"⏸️ Достигнут лимит позиций: {len(self.open_positions)}/{config.MAX_CONCURRENT_POSITIONS}")
            return
        
        self.logger.info(f"📊 Доступно слотов для новых позиций: {available_slots}/{config.MAX_CONCURRENT_POSITIONS}")
        
        signals_found = []
        
        for symbol in watchlist:
            # Пропускаем если уже есть позиция
            if symbol in self.open_positions:
                continue
            
            # Получаем MTF данные
            mtf_data = self.get_mtf_data(symbol)
            
            if not mtf_data:
                continue
            
            # Анализируем сигнал
            signal = self.analyze_mtf_signal(symbol, mtf_data)
            
            if signal:
                signals_found.append({
                    'symbol': symbol,
                    'signal': signal,
                    'price': mtf_data[config.PRIMARY_TIMEFRAME]['close'].iloc[-1]
                })
        
        # Сортируем по уверенности
        signals_found.sort(key=lambda x: x['signal']['confidence'], reverse=True)
        
        # Открываем позиции
        for sig in signals_found:
            if len(self.open_positions) >= config.MAX_CONCURRENT_POSITIONS:
                break
            
            await self.open_position(
                symbol=sig['symbol'],
                direction=sig['signal']['direction'],
                confidence=sig['signal']['confidence'],
                current_price=sig['price']
            )
        
        if not signals_found:
            self.logger.info("📭 Сигналов не найдено")
    
    async def open_position(self, symbol: str, direction: str, confidence: float, current_price: float):
        """Открытие позиции"""
        try:
            self.logger.info(f"🎯 Открываю {direction} позицию: {symbol} (уверенность: {confidence:.1%})")
            
            # Рассчитываем размер позиции
            quantity = calculate_position_size(
                self.client,
                symbol,
                config.POSITION_SIZE_USD,
                config.LEVERAGE,
                current_price
            )
            
            if quantity is None or quantity <= 0:
                self.logger.error(f"❌ Не удалось рассчитать размер позиции для {symbol}")
                return
            
            # Устанавливаем плечо
            try:
                self.client.set_leverage(
                    category="linear",
                    symbol=symbol,
                    buyLeverage=str(config.LEVERAGE),
                    sellLeverage=str(config.LEVERAGE)
                )
            except Exception as e:
                self.logger.warning(f"⚠️ Не удалось установить плечо: {e}")
            
            # Открываем позицию
            side = "Buy" if direction == "LONG" else "Sell"
            
            order = self.client.place_order(
                category="linear",
                symbol=symbol,
                side=side,
                orderType="Market",
                qty=str(quantity),
                timeInForce="GTC",
                positionIdx=0,
            )
            
            if order['retCode'] != 0:
                self.logger.error(f"❌ Ошибка открытия позиции: {order.get('retMsg', 'Unknown')}")
                return
            
            # Сохраняем информацию о позиции
            self.open_positions[symbol] = {
                'direction': direction,
                'entry_price': current_price,
                'quantity': quantity,
                'initial_quantity': quantity,  # ИСХОДНОЕ количество для расчёта TP
                'confidence': confidence,
                'open_time': datetime.now(timezone.utc),
                'tp_levels_hit': [],
                'trailing_sl_active': False,
                'order_id': order['result']['orderId']
            }
            
            # Устанавливаем TP/SL
            await self.set_tp_sl_levels(symbol)
            
            # Отправляем уведомление в Telegram
            await self.telegram.send_position_opened(
                symbol=symbol,
                direction=direction,
                entry_price=current_price,
                quantity=quantity,
                confidence=confidence
            )
            
            self.logger.info(f"✅ Позиция открыта: {symbol} {direction} @ {current_price}")
            
        except Exception as e:
            self.logger.error(f"❌ Ошибка при открытии позиции {symbol}: {e}")
    
    async def set_tp_sl_levels(self, symbol: str):
        """Установка начального SL"""
        if symbol not in self.open_positions:
            return
        
        pos = self.open_positions[symbol]
        
        # Рассчитываем начальный SL
        sl_price = calculate_trailing_sl(
            entry_price=pos['entry_price'],
            direction=pos['direction'],
            max_loss_usd=config.STOP_LOSS_MAX_USD,
            position_size_usd=config.POSITION_SIZE_USD * config.LEVERAGE
        )
        
        # Устанавливаем SL через API
        try:
            self.client.set_trading_stop(
                category="linear",
                symbol=symbol,
                stopLoss=str(round_price(symbol, sl_price)),
                positionIdx=0,
            )
            self.logger.info(f"🛑 Начальный SL установлен: {symbol} @ {sl_price:.6f} (макс. убыток: ${config.STOP_LOSS_MAX_USD})")
        except Exception as e:
            self.logger.error(f"❌ Ошибка установки SL для {symbol}: {e}")
        
        # Сохраняем данные
        pos['sl_price'] = sl_price
        pos['max_profit_percent'] = 0.0
        pos['trailing_sl_active'] = False
    
    async def monitor_positions(self):
        """Мониторинг открытых позиций"""
        if not self.open_positions:
            return
        
        for symbol in list(self.open_positions.keys()):
            await self.check_position(symbol)
    
    async def check_position(self, symbol: str):
        """Проверка позиции и управление безубытком/trailing SL"""
        if symbol not in self.open_positions:
            return
        
        pos = self.open_positions[symbol]
        
        # Получаем текущую цену
        mtf_data = self.get_mtf_data(symbol)
        if not mtf_data or config.PRIMARY_TIMEFRAME not in mtf_data:
            return
        
        current_price = mtf_data[config.PRIMARY_TIMEFRAME]['close'].iloc[-1]
        
        # Проверяем trailing SL (активен всегда, держим до разворота)
        await self.check_trailing_sl(symbol, current_price)
        
        # Проверяем время удержания
        await self.check_position_duration(symbol)
    
    async def check_trailing_sl(self, symbol: str, current_price: float):
        """Проверка и обновление trailing SL (активируется после достижения прибыли)"""
        if symbol not in self.open_positions:
            return
        
        pos = self.open_positions[symbol]
        
        if not config.USE_TRAILING_SL:
            return
        
        # Рассчитываем текущий PnL в процентах
        if pos['direction'] == 'LONG':
            pnl_percent = ((current_price - pos['entry_price']) / pos['entry_price']) * 100
        else:  # SHORT
            pnl_percent = ((pos['entry_price'] - current_price) / pos['entry_price']) * 100
        
        # Активируем trailing при достижении порога (0% = сразу)
        if pnl_percent >= config.TRAILING_SL_ACTIVATION_PERCENT:
            if not pos.get('trailing_sl_active', False):
                pos['trailing_sl_active'] = True
                self.logger.info(f"🔄 Trailing SL активирован для {symbol}")
            
            # Рассчитываем новый trailing SL
            callback_percent = config.TRAILING_SL_CALLBACK_PERCENT / 100
            
            if pos['direction'] == 'LONG':
                new_sl = current_price * (1 - callback_percent)
            else:  # SHORT
                new_sl = current_price * (1 + callback_percent)
            
            # Обновляем SL только если он лучше текущего
            should_update = False
            if pos['direction'] == 'LONG' and new_sl > pos['sl_price']:
                should_update = True
            elif pos['direction'] == 'SHORT' and new_sl < pos['sl_price']:
                should_update = True
            
            if should_update:
                try:
                    self.client.set_trading_stop(
                        category="linear",
                        symbol=symbol,
                        stopLoss=str(round_price(symbol, new_sl)),
                        positionIdx=0,
                    )
                    
                    old_sl = pos['sl_price']
                    pos['sl_price'] = new_sl
                    
                    self.logger.info(
                        f"🔄 Trailing SL обновлён: {symbol} | "
                        f"Старый: {old_sl:.6f} → Новый: {new_sl:.6f}"
                    )
                    
                except Exception as e:
                    self.logger.error(f"❌ Ошибка обновления trailing SL для {symbol}: {e}")
    
    async def check_position_duration(self, symbol: str):
        """Проверка времени удержания позиции"""
        pos = self.open_positions[symbol]
        duration = datetime.now(timezone.utc) - pos['open_time']
        
        if duration.total_seconds() > config.MAX_POSITION_DURATION_HOURS * 3600:
            self.logger.warning(f"⏰ Позиция {symbol} открыта слишком долго, закрываю...")
            await self.close_position(symbol, reason="max_duration")
    
    async def close_position(self, symbol: str, reason: str = "manual"):
        """Закрытие позиции"""
        if symbol not in self.open_positions:
            return
        
        try:
            pos = self.open_positions[symbol]
            
            # Получаем текущую цену для расчёта PnL
            mtf_data = self.get_mtf_data(symbol)
            exit_price = None
            if mtf_data and config.PRIMARY_TIMEFRAME in mtf_data:
                exit_price = mtf_data[config.PRIMARY_TIMEFRAME]['close'].iloc[-1]
            
            # Закрываем позицию на бирже
            side = "Sell" if pos['direction'] == "LONG" else "Buy"
            
            order = self.client.place_order(
                category="linear",
                symbol=symbol,
                side=side,
                orderType="Market",
                qty=str(pos['quantity']),
                timeInForce="GTC",
                positionIdx=0,
                reduceOnly=True
            )
            
            if order['retCode'] == 0:
                # Рассчитываем PnL
                from utils import calculate_pnl, format_duration
                
                if exit_price:
                    pnl_usd, pnl_percent = calculate_pnl(
                        pos['entry_price'],
                        exit_price,
                        pos['direction'],
                        pos['quantity']
                    )
                else:
                    pnl_usd, pnl_percent = 0.0, 0.0
                
                # Время удержания
                duration = (datetime.now(timezone.utc) - pos['open_time']).total_seconds()
                duration_str = format_duration(duration)
                
                self.logger.info(
                    f"✅ Позиция закрыта: {symbol} | "
                    f"PnL: ${pnl_usd:.2f} ({pnl_percent:+.2f}%) | "
                    f"Время: {duration_str} | "
                    f"Причина: {reason}"
                )
                
                # Отправляем уведомление с полной информацией
                await self.telegram.send_position_closed(
                    symbol=symbol,
                    direction=pos['direction'],
                    entry_price=pos['entry_price'],
                    exit_price=exit_price if exit_price else pos['entry_price'],
                    pnl_usd=pnl_usd,
                    pnl_percent=pnl_percent,
                    duration=duration_str,
                    reason=reason
                )
                
                # Удаляем из списка
                del self.open_positions[symbol]
            else:
                self.logger.error(f"❌ Ошибка закрытия позиции {symbol}: {order.get('retMsg', 'Unknown')}")
                
        except Exception as e:
            self.logger.error(f"❌ Ошибка при закрытии позиции {symbol}: {e}")
    
    async def send_daily_report(self):
        """Отправка ежедневного отчёта"""
        if not config.DAILY_REPORT_ENABLED:
            return
        
        try:
            report = self.daily_reporter.generate_daily_report()
            await self.telegram.send_message(report)
            self.logger.info("📊 Ежедневный отчёт отправлен")
        except Exception as e:
            self.logger.error(f"❌ Ошибка отправки ежедневного отчёта: {e}")
    
    def should_send_daily_report(self) -> bool:
        """Проверка нужно ли отправлять ежедневный отчёт"""
        if not config.DAILY_REPORT_ENABLED:
            return False
        
        now = datetime.now(timezone.utc)
        
        # Конвертируем время отчёта в UTC (отчёт в 09:00 UTC+1 = 08:00 UTC)
        report_hour, report_minute = map(int, config.DAILY_REPORT_TIME.split(':'))
        report_hour_utc = (report_hour - 1) % 24  # UTC+1 -> UTC
        
        # Проверяем что сейчас нужное время
        if now.hour != report_hour_utc or now.minute < report_minute:
            return False
        
        # Проверяем что отчёт ещё не отправлялся сегодня
        if self.last_daily_report:
            if self.last_daily_report.date() == now.date():
                return False
        
        return True
    
    # ═══════════════════════════════════════════════════════════════════
    # ВОССТАНОВЛЕНИЕ ПОЗИЦИЙ
    # ═══════════════════════════════════════════════════════════════════
    
    async def restore_positions_from_exchange(self):
        """Восстанавливает открытые позиции с биржи при старте бота"""
        self.logger.info("🔄 Восстановление позиций с биржи...")
        
        try:
            # Получаем все открытые позиции
            response = self.client.get_positions(
                category="linear",
                settleCoin="USDT"
            )
            
            if response['retCode'] != 0:
                self.logger.error(f"❌ Ошибка получения позиций: {response.get('retMsg')}")
                return
            
            positions = response['result']['list']
            restored_count = 0
            
            for pos in positions:
                size = float(pos.get('size', 0))
                
                # Пропускаем закрытые позиции
                if size == 0:
                    continue
                
                symbol = pos['symbol']
                side = pos['side']  # Buy или Sell
                entry_price = float(pos['avgPrice'])
                
                # Определяем направление
                direction = "LONG" if side == "Buy" else "SHORT"
                
                # Восстанавливаем позицию в памяти
                self.open_positions[symbol] = {
                    'symbol': symbol,
                    'direction': direction,
                    'entry_price': entry_price,
                    'quantity': size,
                    'initial_quantity': size,
                    'leverage': int(pos.get('leverage', config.LEVERAGE)),
                    'open_time': datetime.now(timezone.utc),
                    'sl_price': float(pos.get('stopLoss', 0)) if pos.get('stopLoss') else None,
                    'tp_price': float(pos.get('takeProfit', 0)) if pos.get('takeProfit') else None,
                    'max_profit_percent': 0.0,
                    'trailing_sl_active': False,
                    'restored': True,  # Флаг что позиция восстановлена
                }
                
                pnl = float(pos.get('unrealisedPnl', 0))
                
                self.logger.info(
                    f"✅ Восстановлена позиция: {symbol} {direction} | "
                    f"Размер: {size} | Вход: ${entry_price:.4f} | PnL: ${pnl:.2f}"
                )
                
                # Отправляем уведомление в Telegram
                await self.telegram.send_message(
                    f"🔄 <b>ПОЗИЦИЯ ВОССТАНОВЛЕНА</b>\n\n"
                    f"💎 Монета: <b>{symbol}</b>\n"
                    f"📊 Направление: {direction}\n"
                    f"💰 Цена входа: ${entry_price:.6f}\n"
                    f"📦 Размер: {size}\n"
                    f"💵 PnL: ${pnl:.2f}\n\n"
                    f"⚠️ Позиция была открыта до перезапуска бота"
                )
                
                restored_count += 1
            
            if restored_count > 0:
                self.logger.info(f"✅ Восстановлено позиций: {restored_count}")
            else:
                self.logger.info("📭 Нет открытых позиций на бирже")
                
        except Exception as e:
            self.logger.error(f"❌ Ошибка восстановления позиций: {e}")
    
    # ═══════════════════════════════════════════════════════════════════
    # ГЛАВНЫЙ ЦИКЛ
    # ═══════════════════════════════════════════════════════════════════
    
    async def run(self):
        """Главный цикл бота"""
        self.logger.info("🚀 Бот запущен!")
        
        # Запускаем Telegram бота для обработки команд в фоне (в отдельном потоке)
        self.telegram.start()
        self.logger.info("📱 Telegram бот запускается...")
        
        # Даём время на инициализацию
        await asyncio.sleep(3)
        
        # Восстанавливаем позиции с биржи
        await self.restore_positions_from_exchange()
        
        # Отправляем стартовое сообщение
        await self.telegram.send_startup_message()
        self.logger.info("📱 Telegram бот готов принимать команды")
        
        last_analysis = 0
        last_monitoring = 0
        
        try:
            while self.active:
                try:
                    current_time = time.time()
                    
                    # Анализ рынка каждые 15 минут
                    if current_time - last_analysis >= config.ANALYSIS_INTERVAL_SECONDS:
                        await self.scan_and_trade()
                        last_analysis = current_time
                        self.cycle_count += 1
                    
                    # Мониторинг позиций каждую минуту
                    if current_time - last_monitoring >= config.MONITORING_INTERVAL_SECONDS:
                        await self.monitor_positions()
                        last_monitoring = current_time
                    
                    # Проверка ежедневного отчёта
                    if self.should_send_daily_report():
                        await self.send_daily_report()
                        self.last_daily_report = datetime.now(timezone.utc)
                    
                    # Небольшая пауза
                    await asyncio.sleep(10)
                    
                except KeyboardInterrupt:
                    self.logger.info("⏹️ Получен сигнал остановки")
                    break
                except Exception as e:
                    self.logger.error(f"❌ Ошибка в главном цикле: {e}")
                    await asyncio.sleep(60)
        finally:
            # Останавливаем Telegram бота
            self.telegram.stop()
            self.logger.info("👋 Бот остановлен")


async def main():
    """Точка входа"""
    bot = TradingBotV4MTF()
    await bot.run()


if __name__ == "__main__":
    asyncio.run(main())
